DATABASE_URL="postgresql://postgres:password@localhost:5433/pos_restaurant?schema=public"
REDIS_URL="redis://localhost:6379"
APP_PORT=3003
NEXTAUTH_URL="http://localhost:3003"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
NEXT_PUBLIC_APP_URL="https://votre-domaine.example"

# Paiement mobile reel via CinetPay. Sans ces valeurs, l'API refuse l'initialisation.
CINETPAY_APIKEY=""
CINETPAY_SITE_ID=""
CINETPAY_CURRENCY="XOF"
CINETPAY_NOTIFY_URL="https://votre-domaine.example/api/payments/mobile/notify"
CINETPAY_RETURN_URL="https://votre-domaine.example"
CINETPAY_CUSTOMER_COUNTRY="CI"
CINETPAY_CUSTOMER_STATE="CI"
CINETPAY_CUSTOMER_CITY="Abidjan"
CINETPAY_CUSTOMER_ZIP="00000"
CINETPAY_CUSTOMER_EMAIL="client@example.com"

# Agent local optionnel pour imprimante ticket, tiroir-caisse et TPE.
# Exemple: http://127.0.0.1:4555
LOCAL_HARDWARE_AGENT_URL=""
LOCAL_HARDWARE_AGENT_TOKEN=""
