# Base de données PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=pos_restaurant

# Connexion application
DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@pos-db:5432/pos_restaurant?schema=public
DIRECT_DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@pos-db:5432/pos_restaurant?schema=public

# Redis
REDIS_URL=redis://pos-redis:6379

# NextAuth (générer avec: openssl rand -base64 32)
NEXTAUTH_SECRET=CHANGE_ME_GENERATE_RANDOM_32_CHARS
NEXTAUTH_URL=http://localhost:3003

# Sentry (optionnel)
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# Mobile Money (optionnel)
MTN_API_KEY=
ORANGE_API_KEY=

# Livraisons (optionnel)
GLOVO_WEBHOOK_SECRET=
UBEREATS_WEBHOOK_SECRET=
