# /home/theo_pbl/apps/parabellumpos/.env.example

# ⚠️ Ce fichier est un template. Copiez-le vers .env.production et remplissez les valeurs.

# Base de données PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_GENERATED_BY_OPENSSL
POSTGRES_DB=pos_restaurant

# Connexion application
DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@localhost:5433/pos_restaurant?schema=public
DIRECT_DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@localhost:5433/pos_restaurant?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# NextAuth (générer avec: openssl rand -base64 32)
NEXTAUTH_SECRET=CHANGE_ME_GENERATE_RANDOM_32_CHARS
NEXTAUTH_URL=https://parabellumpos.online

# URL publique
NEXT_PUBLIC_APP_URL=https://parabellumpos.online

# Port applicatif
APP_PORT=3003

# Paiement mobile - Obtenez vos clés sur https://cinetpay.com
CINETPAY_APIKEY=CHANGE_ME
CINETPAY_SITE_ID=CHANGE_ME
CINETPAY_CURRENCY=XOF
CINETPAY_NOTIFY_URL=https://parabellumpos.online/api/payments/mobile/notify
CINETPAY_RETURN_URL=https://parabellumpos.online
CINETPAY_CUSTOMER_COUNTRY=CI
CINETPAY_CUSTOMER_STATE=CI
CINETPAY_CUSTOMER_CITY=Abidjan
CINETPAY_CUSTOMER_ZIP=00000
CINETPAY_CUSTOMER_EMAIL=client@example.com

# Hardware local - Installez l'agent sur le PC du tiroir-caisse
# Téléchargement: https://github.com/parabellum/local-hardware-agent
LOCAL_HARDWARE_AGENT_URL=http://127.0.0.1:4555
LOCAL_HARDWARE_AGENT_TOKEN=CHANGE_ME_GENERATE_RANDOM

# Sentry (optionnel)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.05

# Livraisons (optionnel)
GLOVO_WEBHOOK_SECRET=
UBEREATS_WEBHOOK_SECRET=
MTN_API_KEY=
ORANGE_API_KEY=