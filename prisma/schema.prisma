generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum RoundingType {
  NO_ROUNDING
  ROUND_UP
  ROUND_DOWN
  ROUND_NEAREST
}

enum WorkflowType {
  CASHIER_ONLY
  SERVER_FIRST
}

model Store {
  id                  String                    @id @default(cuid())
  name                String
  address             String?
  phone               String?
  email               String?
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt
  commission          Float                     @default(15.0)
  logo                String?
  parentId            String?
  code                String?                   @unique
  timezone            String?                   @default("UTC")
  ecommerceEnabled    Boolean                   @default(false)
  deliveryEnabled     Boolean                   @default(false)
  clickAndCollectEnabled Boolean                @default(true)
  deliveryFee         Decimal?                  @default(0) @db.Decimal(10, 2)
  preparationDelayMinutes Int                   @default(30)
  closedDates         Json?
  parent              Store?                    @relation("StoreSubstores", fields: [parentId], references: [id])
  subStores           Store[]                   @relation("StoreSubstores")
  categories          Category[]
  inventories         Inventory[]
  orders              Order[]
  products            Product[]
  promotions          Promotion[]
  reservations        Reservation[]
  tables              Table[]
  platformConnections StorePlatformConnection[]
  productMappings     ProductPlatformMapping[]
  users               User[]
  productOptions      ProductOption[]
  payouts             Payout[]
  hrConfiguration     HrConfiguration?
  storeSettings       StoreSettings?
  cashDrawerShifts    CashDrawerShift[]
  apiTokens           ApiToken[]
  printers            Printer[]
  PaymentMethod       PaymentMethod[]
  ingredientMovements IngredientMovement[]
  ingredients         Ingredient[]
  deliveryPeople      DeliveryPerson[]
  customers           Customer[]
  suppliers           Supplier[]
  purchaseOrders      PurchaseOrder[]
  transfersFrom       TransferOrder[]           @relation("FromStore")
  transfersTo         TransferOrder[]           @relation("ToStore")
  physicalInventories PhysicalInventory[]
  rolePermissions     RolePermission[]
  customPermissions   CustomPermission[]

  transfersSent       StockTransfer[]           @relation("StockTransferFromStore")
  transfersReceived   StockTransfer[]           @relation("StockTransferToStore")
  consolidatedReports ConsolidatedReport[]      @relation("StoreConsolidatedReports")
  usersMulti          User[]                    @relation("UserStores")
}

model User {
  id        String   @id @default(cuid())
  storeId   String
  name      String
  email     String   @unique
  password  String
  role      Role     @default(CASHIER)
  status    String   @default("ACTIVE") // ACTIVE, INACTIVE, LEAVE, SUSPENDED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // --- Champs RH ---
  matricule        String?   @unique
  firstName        String? // Prénom (name = nom complet)
  civilite         String? // M, Mme
  sexe             String? // M, F
  dateNaissance    DateTime?
  lieuNaissance    String?
  nationalite      String?
  phone            String?
  address          String?
  jobTitle         String? // Poste / Fonction
  department       String? // Service / Département
  hireDate         DateTime?
  endDate          DateTime?
  bankName         String?
  bankAccount      String?
  cnpsNumber       String?
  // Composition familiale pour calcul IGR (Côte d'Ivoire)
  maritalStatus    String? // SINGLE, MARRIED, DIVORCED, WIDOWED
  numberOfChildren Int?      @default(0)
  // Cache rapide (dénormalisé depuis Contract pour affichage)
  contractType     String? // CDI, CDD, Stage, Freelance
  salary           Float? // Salaire de base (FCFA)

  orders              Order[]         @relation("CashierOrders")
  tickets             SupportTicket[]
  store               Store           @relation(fields: [storeId], references: [id])
  contracts           Contract[]
  payrolls            Payroll[]
  leaveRequests       LeaveRequest[]
  loans               Loan[]
  evaluationsReceived Evaluation[]    @relation("UserEvaluations")
  evaluationsGiven    Evaluation[]    @relation("EvaluatorEvaluations")
  history             UserHistory[]
  timecards           Timecard[]
  deliveryOrders      DeliveryOrder[]   @relation("DriverOrders")
  driverTrackings     DeliveryTracking[]
  deliveryDriver      DeliveryDriver?
  stores              Store[]           @relation("UserStores")
  userPermissions     UserPermission[]

  // Sprint 2 — Indexes de performance
  @@index([storeId, role]) // Lister les caissiers/serveurs d'un restaurant
  @@index([storeId, status]) // Employés actifs / en congé par restaurant
}

model PlatformConfig {
  id            String   @id @default("global")
  siteName      String   @default("Ma Plateforme")
  currency      String   @default("FCFA")
  supportEmail  String?
  supportPhone  String?
  minWithdrawal Float    @default(5000)
  enforce2FA    Boolean  @default(false)
  updatedAt     DateTime @updatedAt
}

model SupportTicket {
  id          String       @id @default(cuid())
  subject     String
  description String
  status      TicketStatus @default(OPEN)
  priority    Priority     @default(MEDIUM)
  userId      String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  user        User?        @relation(fields: [userId], references: [id])
}

model DeliveryPerson {
  id          String         @id @default(cuid())
  name        String
  phone       String
  status      DeliveryStatus @default(OFFLINE)
  vehicleType String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  orders      Order[]
  storeId     String
  store       Store          @relation(fields: [storeId], references: [id])

  @@index([storeId])
  @@unique([storeId, phone])
}

model Category {
  id        String          @id @default(cuid())
  storeId   String
  name      String
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  imageUrl  String?
  store     Store           @relation(fields: [storeId], references: [id])
  products  Product[]
  options   ProductOption[]

  // Sprint 2 — Filtre catégories par restaurant (navigation menu)
  @@index([storeId])
}

model Product {
  id                  String                   @id @default(cuid())
  storeId             String
  categoryId          String
  name                String
  description         String?
  price               Float
  costPrice           Float                    @default(0.0)
  image               String?
  barcode             String?                  // Code-barres (EAN-13, UPC, etc.)
  isAvailable         Boolean                  @default(true)
  averagePrepTimeMins Int                      @default(15)
  createdAt           DateTime                 @default(now())
  prepTimeSamples     Int                      @default(0)
  updatedAt           DateTime                 @updatedAt
  minStockLevel       Int                      @default(5)
  stockQuantity       Int                      @default(0)
  trackStock          Boolean                  @default(false)
  orderItems          OrderItem[]
  category            Category                 @relation(fields: [categoryId], references: [id])
  externalMappings    ProductPlatformMapping[]
  store               Store                    @relation(fields: [storeId], references: [id])
  ingredients         ProductIngredient[]      @relation("RecipeIngredients")
  subRecipeFor        ProductIngredient[]      @relation("SubRecipe")
  stockMovements      StockMovement[]
  purchaseOrderItems  PurchaseOrderItem[]
  transferOrderItems  TransferOrderItem[]
  physicalInventoryItems PhysicalInventoryItem[]
  stockTransfers      StockTransfer[]          @relation("ProductStockTransfers")

  @@unique([storeId, barcode])
  @@index([storeId, categoryId, isAvailable])
}

model Order {
  id                   String            @id @default(cuid())
  storeId              String
  cashierId            String?
  customerId           String?
  tableId              String?
  estimatedPrepMinutes Int?
  estimatedReadyAt     DateTime?
  status               OrderStatus       @default(EN_ATTENTE)
  type                 OrderType         @default(DINE_IN)
  total                Float
  actualPrepMinutes    Int?
  createdAt            DateTime          @default(now())
  preparationStartedAt DateTime?
  readyAt              DateTime?
  servedAt             DateTime?
  updatedAt            DateTime          @updatedAt
  deliveryPersonId     String?
  clientRequestId      String?           @unique
  sourcePlatform       DeliveryPlatform?
  externalOrderId      String?
  externalStoreId      String?
  customerName         String?
  customerPhone        String?
  customerEmail        String?
  deliveryAddress      String?
  customerNotes        String?
  externalPayload      Json?
  discount             Float             @default(0)
  source               OrderSource       @default(POS)
  deliveryType         OnlineDeliveryType?
  promotionId          String?
  loyaltyPointsEarned   Int               @default(0)
  loyaltyPointsRedeemed Int               @default(0)
  reservationId        String?
  deliveryOrder        DeliveryOrder?
  cashier              User?             @relation("CashierOrders", fields: [cashierId], references: [id])
  customer             Customer?         @relation(fields: [customerId], references: [id])
  deliveryPerson       DeliveryPerson?   @relation(fields: [deliveryPersonId], references: [id])
  promotion            Promotion?        @relation(fields: [promotionId], references: [id])
  store                Store             @relation(fields: [storeId], references: [id])
  table                Table?            @relation(fields: [tableId], references: [id])
  reservation          Reservation?      @relation(fields: [reservationId], references: [id])
  items                OrderItem[]
  payments             Payment[]
  loyaltyTransactions  LoyaltyTransaction[]

  @@unique([sourcePlatform, externalOrderId])
  @@index([storeId, status])
  @@index([storeId, createdAt])
}

model StorePlatformConnection {
  id              String           @id @default(cuid())
  storeId         String
  platform        DeliveryPlatform
  externalStoreId String
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  store           Store            @relation(fields: [storeId], references: [id])

  @@unique([storeId, platform])
  @@unique([platform, externalStoreId])
}

model ProductPlatformMapping {
  id                String           @id @default(cuid())
  storeId           String
  productId         String
  platform          DeliveryPlatform
  externalProductId String
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  store             Store            @relation(fields: [storeId], references: [id])
  product           Product          @relation(fields: [productId], references: [id])

  @@unique([productId, platform])
  @@unique([storeId, platform, externalProductId])
}

model Promotion {
  id             String       @id @default(cuid())
  storeId        String
  code           String
  description    String?
  discountType   DiscountType @default(PERCENTAGE)
  value          Float
  isActive       Boolean      @default(true)
  startDate      DateTime?
  endDate        DateTime?
  usageLimit     Int?
  usedCount      Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  minOrderAmount Float        @default(0.0)
  maxDiscount    Float?
  applicableTo   String       @default("ALL") // ALL, CATEGORY, PRODUCT
  applicableId   String?      // CategoryId or ProductId if applicableTo is CATEGORY or PRODUCT
  startTime      String?      // HH:MM format
  endTime        String?      // HH:MM format
  daysOfWeek     Int[]        @default([0, 1, 2, 3, 4, 5, 6])
  orders         Order[]
  store          Store        @relation(fields: [storeId], references: [id])

  @@unique([storeId, code])
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Float
  priceExcludingTax Float @default(0)
  taxRate   Float    @default(0.18)
  taxAmount Float    @default(0)
  options   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  order     Order    @relation(fields: [orderId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model Payment {
  id              String               @id @default(cuid())
  orderId         String
  paymentMethodId String?
  status          PaymentStatus        @default(REUSSIE)
  amount          Float
  externalRef     String?
  onlineMethod    OnlinePaymentMethod?
  transactionId   String?              @unique
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  order           Order                @relation(fields: [orderId], references: [id], onDelete: Cascade)
  paymentMethod   PaymentMethod?       @relation(fields: [paymentMethodId], references: [id])

  @@index([orderId])
  @@index([paymentMethodId])
}

model Customer {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  phone     String?
  email     String?
  notes     String?  // Notes sur les préférences / particularités du client
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  loyalty   Loyalty?
  orders    Order[]
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id])

  @@index([storeId])
  @@index([email])
  @@unique([storeId, phone])
}

model Loyalty {
  id               String   @id @default(cuid())
  customerId       String   @unique
  points           Int      @default(0)
  pointsMultiplier Float    @default(1.0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  customer         Customer @relation(fields: [customerId], references: [id])

  @@index([points])
}

model Table {
  id           String        @id @default(cuid())
  storeId      String
  number       Int
  capacity     Int
  status       TableStatus   @default(AVAILABLE)
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  height       Int           @default(100)
  shape        TableShape    @default(RECTANGLE)
  width        Int           @default(100)
  x            Int           @default(0)
  y            Int           @default(0)
  orders       Order[]
  reservations Reservation[]
  store        Store         @relation(fields: [storeId], references: [id])

  @@index([storeId])
  @@unique([storeId, number])
}

model Reservation {
  id            String            @id @default(cuid())
  storeId       String
  tableId       String
  customerName  String
  phone         String
  email         String?
  date          DateTime
  startTime     DateTime
  endTime       DateTime
  guests        Int
  status        ReservationStatus @default(PENDING)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  store         Store             @relation(fields: [storeId], references: [id])
  table         Table             @relation(fields: [tableId], references: [id])
  orders        Order[]
  logs          ReservationLog[]

  @@index([storeId, date])
  @@index([tableId, status])
}

model ReservationLog {
  id            String      @id @default(cuid())
  reservationId String
  action        String
  details       String?
  utilisateur   String?
  timestamp     DateTime    @default(now())
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@index([reservationId])
}

model Ingredient {
  id        String              @id @default(cuid())
  name      String
  unit      String              @default("unité")
  costPrice Float               @default(0.0)
  sellPrice Float               @default(0.0)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  inventory Inventory[]
  products  ProductIngredient[] @relation("BaseIngredient")
  movements IngredientMovement[]
  storeId   String
  store     Store               @relation(fields: [storeId], references: [id])

  @@index([storeId])
  @@unique([storeId, name])
}

model ProductIngredient {
  id                String      @id @default(cuid())
  productId         String      // recette parente
  ingredientId      String      // ingrédient simple (Ingredient) ou sous‑recette (Product)
  quantity          Float
  unit              String      // g, kg, ml, cuillère, etc.
  sectionGroup      String?     // ex: "Pour la pâte", "Pour la farce"
  preparationNote   String?     // ex: "mélanger dans un bol", "laisser reposer 30 min"
  isSubRecipe       Boolean     @default(false) // si true, ingredientId pointe vers une autre recette (Product)
  displayOrder      Int         @default(0)     // ordre d’affichage dans le groupe
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  product           Product     @relation("RecipeIngredients", fields: [productId], references: [id])
  ingredientProduct Product?    @relation("SubRecipe", fields: [ingredientId], references: [id], map: "ProductIngredient_subRecipe_fkey")
  ingredientBase    Ingredient? @relation("BaseIngredient", fields: [ingredientId], references: [id], map: "ProductIngredient_baseIngredient_fkey")

  @@unique([productId, ingredientId, sectionGroup])
}

model Inventory {
  id           String     @id @default(cuid())
  storeId      String
  ingredientId String
  quantity     Float
  minStock     Float
  lastUpdated  DateTime   @default(now())
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  store        Store      @relation(fields: [storeId], references: [id])

  @@unique([storeId, ingredientId])
}

model ProductOption {
  id         String     @id @default(cuid())
  storeId    String
  name       String
  price      Float      @default(0)
  type       OptionType
  categoryId String?
  store      Store      @relation(fields: [storeId], references: [id])
  category   Category?  @relation(fields: [categoryId], references: [id])

  @@unique([storeId, name, categoryId, type])
  @@index([categoryId])
}

// Historique complet des mouvements de stock — indispensable pour l'auditabilité
model StockMovement {
  id          String    @id @default(cuid())
  productId   String
  storeId     String
  quantity    Int // positif = entrée, négatif = sortie
  reason      MvtReason
  referenceId String? // orderId si reason = SALE
  note        String? // note optionnelle pour les ajustements manuels
  createdAt   DateTime  @default(now())
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, createdAt])
  @@index([storeId, createdAt])
  @@index([storeId, reason])
}

enum MvtReason {
  SALE // Déduit lors de la création d'une commande
  ADJUSTMENT // Ajustement manuel par un admin
  WASTE // Perte / casse
  DELIVERY // Entrée de stock fournisseur
  TRANSFER_IN
  TRANSFER_OUT
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum OptionType {
  SUPPLEMENT
  REMOVAL
}

enum Role {
  ADMIN
  RESTAURATEUR
  CASHIER
  SERVER
  KITCHEN
  DELIVERY
  MANAGER
  LIVREUR
  SUPER_ADMIN
  STORE_MANAGER
  STORE_EMPLOYEE
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum DeliveryStatus {
  ONLINE
  OFFLINE
  BUSY
}

enum DeliveryPlatform {
  GLOVO
  UBER_EATS
  DELIVEROO
  GENERIC
}

enum OrderStatus {
  EN_ATTENTE
  PREPARATION @map("PRÉPARATION")
  PRET        @map("PRÊT")
  COMPLETED
  CANCELLED
}

enum OrderType {
  DINE_IN
  TAKEAWAY
  DELIVERY
}

enum PaymentType {
  CASH
  CARD
  MOBILE_MONEY
  CHECK
  MEAL_VOUCHER
  GIFT_CARD
  OTHER
}

model PaymentMethod {
  id           String      @id @default(cuid())
  name         String // "Espèces", "Carte", "Mobile Money", "Ticket resto"
  type         PaymentType
  isActive     Boolean     @default(true)
  isDefault    Boolean     @default(false)
  icon         String? // emoji ou URL icône
  storeId      String? // null = global, sinon spécifique magasin
  displayOrder Int         @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  store    Store?    @relation(fields: [storeId], references: [id])
  payments Payment[]

  @@unique([name, storeId])
  @@index([storeId, isActive])
  @@index([type])
}

enum PaymentStatus {
  EN_ATTENTE
  REUSSIE
  ECHOUEE
  REMBOURSEE
}

enum OrderSource {
  ONLINE
  POS
}

enum OnlineDeliveryType {
  DELIVERY
  CLICK_AND_COLLECT
}

enum OnlinePaymentMethod {
  CARD
  ORANGE_MONEY
  MTN_MONEY
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  SEATED
  EN_ATTENTE
  COMPLETED
}

enum TableShape {
  RECTANGLE
  CIRCLE
}

model Payout {
  id        String   @id @default(cuid())
  storeId   String
  amount    Float
  status    String   @default("COMPLETED")
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  store     Store    @relation(fields: [storeId], references: [id])
}

// ════════════════════════════════════════
// MODULE RH : CONTRATS & CARRIÈRE
// ════════════════════════════════════════

model Contract {
  id               String    @id @default(cuid())
  userId           String
  type             String // CDI, CDD, Stage, Freelance
  startDate        DateTime
  endDate          DateTime?
  position         String? // Poste
  department       String? // Département
  baseSalary       Float
  status           String    @default("ACTIVE") // ACTIVE, TERMINATED, EXPIRED
  terminationDate  DateTime?
  terminationNote  String?
  maritalStatus    String? // Copie au moment du contrat
  numberOfChildren Int?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

// ════════════════════════════════════════
// MODULE RH : PAIE
// ════════════════════════════════════════

model Payroll {
  id             String    @id @default(cuid())
  userId         String
  period         String // "2025-01", "2025-02", ...
  baseSalary     Float
  socialSecurity Float     @default(0) // CNPS Salariale
  taxAmount      Float     @default(0) // ITS + CN + IGR
  netSalary      Float
  employerCost   Float     @default(0) // CNPS Patronale
  details        Json?     // Détail comptable complet (lignes de gains, cotisations, indemnités)
  paymentStatus  String    @default("PENDING") // PENDING, PAID
  paymentDate    DateTime?
  reference      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, period])
  @@index([period])
}

// ════════════════════════════════════════
// MODULE RH : CONGÉS
// ════════════════════════════════════════

model LeaveRequest {
  id           String    @id @default(cuid())
  userId       String
  type         String // PAID, SICK, MATERNITY, UNPAID, OTHER
  startDate    DateTime
  endDate      DateTime
  daysCount    Int
  status       String    @default("PENDING") // PENDING, APPROVED, REJECTED
  reason       String?
  approvedBy   String?
  approvedAt   DateTime?
  rejectedNote String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([startDate, endDate])
}

// ════════════════════════════════════════
// MODULE RH : AVANCES & PRÊTS
// ════════════════════════════════════════

model Loan {
  id               String    @id @default(cuid())
  userId           String
  type             String // ADVANCE, LOAN
  amount           Float
  monthlyDeduction Float? // Pour les prêts uniquement
  status           String    @default("PENDING") // PENDING, APPROVED, REJECTED, SETTLED
  reason           String?
  approvedBy       String?
  approvedAt       DateTime?
  settledAt        DateTime?
  note             String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

// ════════════════════════════════════════
// MODULE RH : ÉVALUATIONS
// ════════════════════════════════════════

model Evaluation {
  id           String   @id @default(cuid())
  userId       String // Employé évalué
  evaluatorId  String // Manager qui évalue
  period       String // "2025-Q1", "2025-ANNUEL"
  overallScore Int // Note globale /5
  criteria     Json? // {ponctualite: 4, qualite: 5, ...}
  strengths    String?
  improvements String?
  goals        String?
  comment      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation("UserEvaluations", fields: [userId], references: [id], onDelete: Cascade)
  evaluator    User     @relation("EvaluatorEvaluations", fields: [evaluatorId], references: [id])

  @@index([userId, period])
}

// ════════════════════════════════════════
// MODULE RH : HISTORIQUE
// ════════════════════════════════════════

model UserHistory {
  id          String   @id @default(cuid())
  userId      String
  action      String // CONTRACT_CREATED, SALARY_UPDATED, STATUS_CHANGED, ...
  description String?
  metadata    Json?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// ════════════════════════════════════════
// MODULE RH : CONFIGURATION FISCALE
// ════════════════════════════════════════

model HrConfiguration {
  id                String   @id @default(cuid())
  storeId           String   @unique
  cnpsEmployeeRate  Float    @default(6.3) // Taux salarial CNPS (%)
  cnpsEmployerRate  Float    @default(16.45) // Taux patronal CNPS (%)
  itsRate           Float    @default(1.2) // ITS (%)
  baseImposableRate Float    @default(80.0) // Base imposable (% du brut)
  cnpsCeiling       Float    @default(1647315) // Plafond CNPS annuel (FCFA)
  igrBaseRate       Float    @default(85.0) // Base IGR (% du net imposable)
  taxRates          Json? // Barèmes CN et IGR personnalisés
  // --- Informations Entreprise (pour bulletin de paie) ---
  nomEntreprise       String?  // Raison sociale
  adresseSiege        String?  // Adresse complète
  telephone           String?  // Téléphone entreprise
  registreCommerce    String?  // N° RC
  compteContribuable  String?  // N° CC
  numeroCnps          String?  // N° Employeur CNPS
  // --- Configuration Présences ---
  horaireJournalier   Float?   @default(8.0)  // Heures par jour
  joursParSemaine     Int?     @default(5)    // Jours travaillés par semaine
  // --- Taux cotisations patronales supplémentaires ---
  cmuRate             Float?   @default(0.0)  // CMU % (Couverture Maladie Universelle)
  formationRate       Float?   @default(0.6)  // Formation continue %
  apprentissageRate   Float?   @default(0.4)  // Taxe d'apprentissage %
  prestFamilialeRate  Float?   @default(5.75) // Prestation familiale %
  accidentTravailRate Float?   @default(3.0)  // Accident de travail %
  cmuSalarialFixe     Float?   @default(1000) // CMU part salariale fixe (FCFA)
  cmuPatronalFixe     Float?   @default(500)  // CMU part patronale fixe (FCFA)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  store             Store    @relation(fields: [storeId], references: [id])
}

model StoreSettings {
  id            String       @id @default(cuid())
  storeId       String       @unique
  rounding      RoundingType @default(NO_ROUNDING)
  roundingValue Int          @default(5)
  receiptLogo   String?      @db.Text // Base64 du logo pour impression ESC/POS
  receiptHeader String? // Texte personnalisé en-tête de reçu
  receiptFooter String? // Texte personnalisé pied de reçu
  workflowType  WorkflowType @default(SERVER_FIRST)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  store         Store        @relation(fields: [storeId], references: [id])
}

model Printer {
  id            String   @id @default(cuid())
  storeId       String
  name          String // e.g. "Imprimante Cuisine", "Imprimante Comptoir"
  type          String // "ETHERNET", "USB", "BLUETOOTH"
  ipAddress     String? // e.g. "192.168.1.100"
  port          Int      @default(9100)
  paperWidth    Int      @default(80) // 80 or 58 (mm)
  printReceipts Boolean  @default(true) // Ticket de caisse
  printOrders   Boolean  @default(false) // Bons de préparation cuisine
  categories    String? // Catégories associées sous forme de chaîne de caractères (ex: "boissons,desserts")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  store         Store    @relation(fields: [storeId], references: [id])

  @@index([storeId])
}

model CashDrawerShift {
  id             String                @id @default(cuid())
  storeId        String
  openedById     String
  openedByName   String
  openedAt       DateTime              @default(now())
  closedById     String?
  closedByName   String?
  closedAt       DateTime?
  startAmount    Int // Fond de caisse initial (FCFA)
  endAmount      Int? // Saisie montant final (FCFA)
  expectedAmount Int? // Calculé attendu (startAmount + ventes espèces + payIn - payOut)
  status         ShiftStatus           @default(OPEN)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  store          Store                 @relation(fields: [storeId], references: [id])
  operations     CashDrawerOperation[]

  @@index([storeId])
  @@index([status])
}

model CashDrawerOperation {
  id        String          @id @default(cuid())
  shiftId   String
  amount    Int // Montant de l'opération (FCFA)
  type      OperationType
  note      String? // Motif de l'opération
  createdAt DateTime        @default(now())
  shift     CashDrawerShift @relation(fields: [shiftId], references: [id], onDelete: Cascade)

  @@index([shiftId])
}

enum ShiftStatus {
  OPEN
  CLOSED
}

enum OperationType {
  PAY_IN
  PAY_OUT
}

model ApiToken {
  id        String   @id @default(cuid())
  storeId   String
  name      String // Nom descriptif (ex: "Intégration Apify")
  token     String   @unique // Jeton sécurisé haché ou brut (GLP_...)
  prefix    String // Masked preview (ex: "GLP_abcd")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
}

model IngredientMovement {
  id           String       @id @default(cuid())
  ingredientId String
  storeId      String
  quantity     Float        // positive = added, negative = removed
  reason       IngMvtReason
  note         String?
  createdAt    DateTime     @default(now())
  
  ingredient   Ingredient   @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  store        Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  
  @@index([ingredientId, createdAt])
  @@index([storeId, createdAt])
}

enum IngMvtReason {
  TRANSFER_OUT
  TRANSFER_IN
  ADJUSTMENT_LOSS // Perte
  ADJUSTMENT_THEFT // Vol
  ADJUSTMENT_WASTE // Casse
  ADJUSTMENT_CORRECTION // Correction manuelle
  INITIAL_STOCK // Stock initial
  DELIVERY // Livraison fournisseur
}

// Fournisseurs
model Supplier {
  id          String    @id @default(cuid())
  storeId     String
  name        String
  email       String?
  phone       String?
  address     String?
  contactName String?
  taxId       String?
  notes       String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  store       Store     @relation(fields: [storeId], references: [id])
  purchaseOrders PurchaseOrder[]
  
  @@index([storeId])
  @@unique([storeId, name])
}

// Bons de commande fournisseurs
model PurchaseOrder {
  id           String            @id @default(cuid())
  poNumber     String            @unique
  storeId      String
  supplierId   String
  status       PurchaseOrderStatus @default(DRAFT)
  orderDate    DateTime          @default(now())
  expectedDate DateTime?
  receivedDate DateTime?
  notes        String?
  subtotal     Float
  taxAmount    Float
  totalAmount  Float
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  store        Store             @relation(fields: [storeId], references: [id])
  supplier     Supplier          @relation(fields: [supplierId], references: [id])
  items        PurchaseOrderItem[]
  
  @@index([storeId, status])
  @@index([supplierId])
}

model PurchaseOrderItem {
  id               String        @id @default(cuid())
  purchaseOrderId  String
  productId        String
  quantity         Int
  receivedQuantity Int           @default(0)
  unitCost         Float
  totalCost        Float
  notes            String?
  purchaseOrder    PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product          Product       @relation(fields: [productId], references: [id])
  
  @@unique([purchaseOrderId, productId])
}

// Ordres de transfert inter-magasins
model TransferOrder {
  id               String            @id @default(cuid())
  transferNumber   String            @unique
  fromStoreId      String
  toStoreId        String
  status           TransferStatus    @default(PENDING)
  requestedBy      String
  approvedBy       String?
  requestDate      DateTime          @default(now())
  shipDate         DateTime?
  receiveDate      DateTime?
  notes            String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  fromStore        Store             @relation("FromStore", fields: [fromStoreId], references: [id])
  toStore          Store             @relation("ToStore", fields: [toStoreId], references: [id])
  items            TransferOrderItem[]
  
  @@index([fromStoreId, status])
  @@index([toStoreId, status])
}

model TransferOrderItem {
  id               String         @id @default(cuid())
  transferOrderId  String
  productId        String
  quantity         Int
  receivedQuantity Int            @default(0)
  unitCost         Float
  totalCost        Float
  transferOrder    TransferOrder  @relation(fields: [transferOrderId], references: [id], onDelete: Cascade)
  product          Product        @relation(fields: [productId], references: [id])
  
  @@unique([transferOrderId, productId])
}

// Inventaire physique (comptage)
model PhysicalInventory {
  id          String                @id @default(cuid())
  storeId     String
  name        String
  status      InventoryStatus       @default(DRAFT)
  scheduledDate DateTime?
  completedAt DateTime?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  store       Store                 @relation(fields: [storeId], references: [id])
  items       PhysicalInventoryItem[]
  
  @@index([storeId, status])
}

model PhysicalInventoryItem {
  id                  String            @id @default(cuid())
  physicalInventoryId String
  productId           String
  expectedQuantity    Float
  countedQuantity     Float?
  difference          Float?            // counted - expected
  notes               String?
  physicalInventory   PhysicalInventory @relation(fields: [physicalInventoryId], references: [id], onDelete: Cascade)
  product             Product           @relation(fields: [productId], references: [id])
  
  @@unique([physicalInventoryId, productId])
}

// Enums
enum PurchaseOrderStatus {
  DRAFT
  SENT
  PARTIAL
  RECEIVED
  CANCELLED
}

enum TransferStatus {
  PENDING
  APPROVED
  SHIPPED
  RECEIVED
  CANCELLED
}

enum InventoryStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// Suivi du temps de travail (Pointage / Fiches de présence)
model Timecard {
  id        String    @id @default(cuid())
  storeId   String
  userId    String
  clockIn   DateTime  @default(now())
  clockOut  DateTime?
  duration  Float?    // en heures
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([storeId, userId])
}

// Droits d'accès personnalisés
model RolePermission {
  id            String   @id @default(cuid())
  storeId       String
  role          Role
  permissionKey String
  enabled       Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  store         Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, role, permissionKey])
  @@index([storeId, role])
}

model ClotureMois {
  id        String   @id @default(cuid())
  storeId   String
  period    String   // "2026-06", etc.
  isClosed  Boolean  @default(true)
  closedAt  DateTime @default(now())
  closedBy  String

  @@unique([storeId, period])
  @@index([storeId])
}

enum LoyaltyTransactionType {
  EARN
  REDEEM
}

model LoyaltyCustomer {
  id           String               @id @default(cuid())
  phone        String               @unique
  email        String?
  nom          String?
  points       Int                  @default(0)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  transactions LoyaltyTransaction[]
}

model LoyaltyTransaction {
  id          String                 @id @default(cuid())
  customerId  String
  orderId     String?
  type        LoyaltyTransactionType
  points      Int
  description String
  createdAt   DateTime               @default(now())
  customer    LoyaltyCustomer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  order       Order?                 @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@index([orderId])
}

model LoyaltyReward {
  id          String   @id @default(cuid())
  code        String   @unique
  label       String
  description String?
  pointsCost  Int
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model DeliveryOrder {
  id                   String              @id @default(cuid())
  orderId              String              @unique
  address              String
  latitude             Decimal?
  longitude            Decimal?
  distanceKm           Decimal?
  deliveryFee          Decimal
  status               DeliveryOrderStatus @default(PENDING)
  estimatedTimeMinutes Int?
  startedAt            DateTime?
  deliveredAt          DateTime?
  livreurId            String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  order                Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  livreur              User?               @relation("DriverOrders", fields: [livreurId], references: [id], onDelete: SetNull)
  trackings            DeliveryTracking[]

  @@index([livreurId])
  @@index([status])
}

model DeliveryDriver {
  id             String   @id @default(cuid())
  userId         String   @unique
  vehicleType    String?
  isActive       Boolean  @default(true)
  latitude       Decimal?
  longitude      Decimal?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DeliveryTracking {
  id              String        @id @default(cuid())
  deliveryOrderId String
  livreurId       String
  latitude        Decimal
  longitude       Decimal
  timestamp       DateTime      @default(now())
  deliveryOrder   DeliveryOrder @relation(fields: [deliveryOrderId], references: [id], onDelete: Cascade)
  livreur         User          @relation(fields: [livreurId], references: [id], onDelete: Cascade)

  @@index([deliveryOrderId])
  @@index([livreurId])
}

enum DeliveryOrderStatus {
  PENDING
  ASSIGNED
  PICKED_UP
  IN_PROGRESS
  DELIVERED
  CANCELLED
}

enum StockTransferStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

model StockTransfer {
  id          String              @id @default(cuid())
  fromStoreId String
  toStoreId   String
  productId   String
  quantity    Int
  status      StockTransferStatus @default(PENDING)
  requestedAt DateTime            @default(now())
  completedAt DateTime?
  notes       String?

  fromStore   Store               @relation("StockTransferFromStore", fields: [fromStoreId], references: [id])
  toStore     Store               @relation("StockTransferToStore", fields: [toStoreId], references: [id])
  product     Product             @relation("ProductStockTransfers", fields: [productId], references: [id])

  @@index([fromStoreId])
  @@index([toStoreId])
  @@index([productId])
}

model ConsolidatedReport {
  id         String   @id @default(cuid())
  storeId    String
  date       DateTime
  ca         Float
  marge      Float
  nbOrders   Int
  nbCouverts Int

  store      Store    @relation("StoreConsolidatedReports", fields: [storeId], references: [id])

  @@unique([storeId, date])
}

model UserPermission {
  id            String   @id @default(cuid())
  userId        String
  permissionKey String
  enabled       Boolean
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionKey])
  @@index([userId])
}

model CustomPermission {
  id            String   @id @default(cuid())
  storeId       String
  permissionKey String
  name          String
  desc          String
  module        String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  store         Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, permissionKey])
  @@index([storeId])
}
